{
  "name": "taskhub",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": {
    "packages": [
      "apps/*"
    ],
    "nohoist": [
      "**/@nestjs/apollo",
      "**/@nestjs/apollo/**",
      "**/@apollo/server",
      "**/@apollo/server/**",
      "**/@as-integrations/**",
      "**/@nestjs/graphql",
      "**/@nestjs/graphql/**",
      "**/graphql",
      "**/graphql/**"
    ]
  },
  "scripts": {
    "dev": "turbo run dev --filter=@taskhub/web",
    "dev:all": "turbo run dev",
    "api": "turbo run dev --filter=@taskhub/api",
    "web": "turbo run dev --filter=@taskhub/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prisma:generate": "yarn workspace @taskhub/api prisma:generate",
    "prisma:migrate": "yarn workspace @taskhub/api prisma:migrate",
    "prisma:migrate:create": "yarn workspace @taskhub/api prisma:migrate:create",
    "prisma:reset": "yarn workspace @taskhub/api prisma:reset",
    "prisma:push": "yarn workspace @taskhub/api prisma:push",
    "prisma:deploy": "yarn workspace @taskhub/api prisma:deploy",
    "prisma:studio": "yarn workspace @taskhub/api prisma:studio",
    "prisma:seed": "yarn workspace @taskhub/api prisma:seed",
    "seed": "yarn workspace @taskhub/api prisma:seed"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  }
}
