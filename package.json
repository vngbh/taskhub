{
  "name": "taskhub",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "nohoist": [
      "**/@nestjs/apollo",
      "**/@nestjs/apollo/**",
      "**/@apollo/server",
      "**/@apollo/server/**",
      "**/@as-integrations/**",
      "**/@nestjs/graphql",
      "**/@nestjs/graphql/**",
      "**/graphql",
      "**/graphql/**"
    ]
  },
  "scripts": {
    "dev": "turbo run dev",
    "api": "yarn workspace @taskhub/api dev",
    "web": "yarn workspace @taskhub/web dev",
    "build": "turbo run build",
    "seed": "yarn workspace @taskhub/database seed",
    "prisma:migrate": "yarn workspace @taskhub/database db:migrate",
    "prisma:generate": "yarn workspace @taskhub/database db:generate",
    "prisma:deploy": "yarn workspace @taskhub/database db:deploy",
    "prisma:studio": "yarn workspace @taskhub/database db:studio"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  }
}
